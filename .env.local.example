# Copy this file to `.env.local` and fill in real values.
# Never commit `.env.local` (it is gitignored); only this example is tracked.

# --- Supabase (required) ---
# Project URL and public anon key — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Service-role key — SERVER ONLY, bypasses RLS. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Payments (required if using Stripe checkout) ---
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# --- Cron / queue processing (required for the queue endpoint) ---
# Shared secret the /api/queue/process endpoint checks (Bearer token).
CRON_SECRET=generate-a-long-random-string

# --- Site config ---
# Public base URL, used to build payment return URLs, sitemap, etc.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Optional toggles ---
# Set to "false" to bypass the server-side query cache (unstable_cache) at runtime.
ENABLE_QUERY_CACHE=true
