# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# python
__pycache__/
*.pyc

# generated reports
/tools/output/

# sensitive and large data
/.agent/
/archive/
/TOMfiles/
/Cards/

# schema dumps (use db/schema/ as source of truth)
/schema.json
/prod_simplified_schema.txt

# local dev scripts and artifacts
*.log
lint*.json
lint*.txt
/tmp/

# debug/test scripts (not part of the app)
/scripts/
/tools/
/db/schema/
test-queries.ts

# reference docs (not app-functional)
docs/*.pdf
docs/sample-tournament.xml
