# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# python
__pycache__/
*.pyc

# generated reports
/tools/

# sensitive and large data
/.agent/
/archive/
/TOMfiles/
/Cards/

# schema dumps (regenerated from live DB)
/schema.json
/prod_simplified_schema.txt

# local dev artifacts
*.log
lint*.json
lint*.txt
/tmp/

# debug/test scripts (not part of the app)
# NOTE: scripts/lint-structure.js is EXCLUDED — CI depends on it (npm run lint:structure)
/scripts/*
!/scripts/lint-structure.js
test-queries.ts

# historical SQL (canonical history lives in supabase/migrations/)
/db/features/
/db/fixes/
/db/security/
/db/schema/

# documentation (not app-functional, keep README.md for GitHub)
/docs/

# editor/workspace config
*.code-workspace

# unused default Next.js scaffold assets (not referenced by any code)
public/file.svg
public/globe.svg
public/next.svg
public/vercel.svg
public/window.svg
